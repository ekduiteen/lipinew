# ============================================================================
# LIPI Environment Configuration
# Copy to .env and fill in values. Never commit .env to git.
# ============================================================================

# ─── App ────────────────────────────────────────────────────────────────────
APP_NAME=LIPI
# Production: https://yourdomain.com  Dev: http://localhost:3000
APP_URL=https://lipi.local
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Testing Mode (Regular LLM without teach behaviors) ──────────────────────
# Set to true to disable teach mode and use LIPI as a regular chatbot
# This removes language steering, elicitation goals, and behavior policies
LIPI_DISABLE_TEACH_BEHAVIORS=false

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=lipi
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=lipi
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://lipi:change_me_in_production@postgres:5432/lipi

# ─── Valkey (NOT Redis) ─────────────────────────────────────────────────────
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_URL=valkey://valkey:6379/0
ENABLE_INTENT_RECOGNITION=true
ENABLE_ENTITY_EXTRACTION=true
ENABLE_KEYTERM_BOOSTING=true
MAX_SESSION_KEYTERMS=10
MAX_TEACHER_HISTORY_KEYTERMS=8
MAX_ADMIN_SEED_KEYTERMS=12
TRANSCRIPT_REPAIR_ENABLED=true
TRANSCRIPT_REPAIR_MIN_CONFIDENCE=0.86
LEARNING_MIN_INTENT_CONFIDENCE=0.55
LEARNING_MIN_ENTITY_CONFIDENCE=0.60

# ─── MinIO (S3-compatible storage) ──────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=lipi_minio_admin
MINIO_SECRET_KEY=change_me_in_production
MINIO_BUCKET_AUDIO=lipi-audio
MINIO_BUCKET_TTS=lipi-tts
MINIO_BUCKET_ARCHIVES=lipi-archives
MINIO_USE_SSL=false

# ─── vLLM (Self-hosted LLM) ─────────────────────────────────────────────────
VLLM_URL=http://vllm:8080
VLLM_MODEL=lipi
VLLM_TIMEOUT=20.0
VLLM_MAX_TOKENS=512
VLLM_TEMPERATURE=0.7

# ─── ML Service (STT + TTS) ─────────────────────────────────────────────────
ML_SERVICE_URL=http://ml:5001
STT_TIMEOUT=10.0
TTS_TIMEOUT=10.0

# ─── API Fallback (Reliability only — fires on local failure) ───────────────
GROQ_API_KEY=
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_STT_MODEL=whisper-large-v3
ENABLE_API_FALLBACK=true

# ─── Auth ───────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://lipi.local
NEXTAUTH_SECRET=change_me_to_random_32_byte_hex
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_AUTH_ORIGIN=https://lipi.local

# Phone auth (Twilio or similar)
PHONE_AUTH_PROVIDER=
PHONE_AUTH_API_KEY=

# ─── Frontend (Next.js) ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://lipi.local/api
NEXT_PUBLIC_WS_URL=wss://lipi.local/ws
NEXT_PUBLIC_APP_NAME=LIPI

# ─── Backend (FastAPI) ──────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
JWT_SECRET=change_me_to_random_32_byte_hex
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=720

# ─── GPU Configuration ──────────────────────────────────────────────────────
CUDA_VISIBLE_DEVICES=0,1
VLLM_TENSOR_PARALLEL_SIZE=2
VLLM_GPU_MEMORY_UTILIZATION=0.85
STT_DEVICE=cuda:0
TTS_DEVICE=cuda:0
WHISPER_LANGUAGE_HINT=ne
WHISPER_INITIAL_PROMPT=नमस्ते। म नेपाली बोल्छु। तपाईं, तिमी, म, नेपाली, भाषा, शिक्षक, लिपि।

# ─── TTS Provider ────────────────────────────────────────────────────────────
# TTS_PROVIDER=coqui  → Coqui XTTSv2 primary + Piper fallback (default)
# TTS_PROVIDER=piper  → Piper only (use during initial rollout testing)
TTS_PROVIDER=coqui

# Coqui XTTSv2 settings
# Model is downloaded on first run (~1.8 GB). Mount a Docker volume at
# TTS_HOME (default: ~/.local/share/tts) to persist across container restarts.
XTTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_SPEAKER=Claribel Dervla
# XTTS_REFERENCE_WAV=  # leave empty for built-in speaker; set to a path of a
#                       # 6-30 second clean speech WAV to enable voice cloning

# Piper fallback voices (always loaded, used when Coqui fails)
PIPER_VOICE_ID=ne_NP-google-medium
PIPER_VOICE_ID_NE=ne_NP-google-medium
PIPER_VOICE_ID_EN=en_US-lessac-medium
PIPER_LENGTH_SCALE=1.25
PIPER_SENTENCE_SILENCE=0.15

# ─── Monitoring ─────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=change_me

# ─── Caddy (Reverse proxy) ──────────────────────────────────────────────────
CADDY_DOMAIN=lipi.local
CADDY_EMAIL=admin@lipi.local
